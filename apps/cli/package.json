{
  "name": "clickup-cli",
  "version": "0.1.0",
  "bin": {
    "clickup": "./dist/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "bun build src/index.ts --compile --outfile dist/clickup",
    "dev": "bun run src/index.ts",
    "start": "node dist/index.js",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint src",
    "typecheck": "tsc --noEmit",
    "test": "echo 'No tests yet'",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@clickup/api": "workspace:*",
    "@inquirer/prompts": "^8.3.2",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "inquirer": "^13.3.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/inquirer": "catalog:"
  }
}
