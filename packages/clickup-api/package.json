{
  "name": "@clickup/api",
  "version": "0.1.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "clean": "rm -rf dist",
    "update-openapi": "curl -o openapi/clickup-api-v2-reference.json https://developer.clickup.com/openapi/clickup-api-v2-reference.json",
    "generate": "orval --config ./orval.config.ts && sed -i \"s/formData.append/\\/\\/ @ts-expect-error orval generates incorrect FormData.append call\\nformData.append/\" ./src/generated/api.ts",
    "generate:watch": "orval --config ./orval.config.ts --watch"
  },
  "dependencies": {
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "orval": "^8.5.3",
    "vitest": "^1.0.0"
  }
}