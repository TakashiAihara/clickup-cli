{
  "name": "clickup-cli-monorepo",
  "version": "0.3.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "catalog": {
    "typescript": "^6.0.2",
    "vitest": "^4.1.1",
    "oxlint": "^1.57.0",
    "oxfmt": "^0.42.0",
    "axios": "^1.13.6",
    "zod": "^4.3.6",
    "orval": "^8.6.2",
    "@types/inquirer": "^9.0.9"
  },
  "scripts": {
    "build": "bun run --filter '*' build",
    "dev": "bun run --filter '*' dev",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "bun run --filter '*' lint",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun run --filter '*' test",
    "clean": "bun run --filter '*' clean"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
